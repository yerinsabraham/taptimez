# Firebase web config — copy this file to `.env.local` and fill in real values.
# Get these from the Firebase console:
#   Project settings (gear icon) > General > Your apps > Web app > SDK setup & config
#
# NOTE: these values are public by design (they ship in the client bundle).
# Security comes from Firebase Auth + Security Rules, not from hiding these.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=timitiming-21d9a.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=timitiming-21d9a
VITE_FIREBASE_STORAGE_BUCKET=timitiming-21d9a.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=929786167291
VITE_FIREBASE_APP_ID=
# Realtime Database URL (create the DB in the console, then paste its URL here)
VITE_FIREBASE_DATABASE_URL=
