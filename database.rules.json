{
  "rules": {
    ".read": false,
    ".write": false,
    "rooms": {
      "$code": {
        ".read": "auth != null",
        ".write": "auth != null && ( !data.exists() || data.child('participants').child(auth.uid).exists() || newData.child('participants').child(auth.uid).exists() || (!newData.exists() && !data.child('participants').exists()) )"
      }
    },
    "presence": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid"
      }
    }
  }
}
